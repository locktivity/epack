package main

import (
	"fmt"

	"github.com/locktivity/epack/componentsdk"
)

// Version is set by ldflags at build time.
var Version = "dev"

func main() {
	componentsdk.RunTool(componentsdk.ToolSpec{
		Name:         "{{.Name}}",
		Version:      Version,
		Description:  "TODO: Describe what this tool does",
		RequiresPack: true,
		Network:      false,
	}, run)
}

func run(ctx componentsdk.ToolContext) error {
	pack := ctx.Pack()

	// Report status updates (shown in CLI spinner/progress)
	ctx.Status("Analyzing evidence pack...")

	artifacts := pack.Artifacts()
	total := int64(len(artifacts))

	// TODO: Implement your tool logic here
	// Example: iterate over artifacts with progress reporting
	for i, artifact := range artifacts {
		// Report progress (current/total shown in CLI)
		ctx.Progress(int64(i+1), total, fmt.Sprintf("Processing %s", artifact.Path))

		data, err := pack.ReadArtifact(artifact.Path)
		if err != nil {
			continue
		}

		// Process artifact data...
		_ = data
	}

	ctx.Status("Analysis complete")

	// Write output
	result := map[string]any{
		"message":   "Tool executed successfully",
		"artifacts": len(artifacts),
	}
	return ctx.WriteOutput("output.json", result)
}
